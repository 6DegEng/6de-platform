# Default: auto-normalize, treat as text
* text=auto eol=lf

# Force LF on code files (prevent OneDrive CRLF corruption)
*.py text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.txt text eol=lf
*.sql text eol=lf
*.sh text eol=lf
*.bat text eol=crlf
*.ps1 text eol=crlf
*.cmd text eol=crlf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf

# Binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.xlsx binary
*.docx binary
*.db binary
*.sqlite binary
*.sqlite3 binary
